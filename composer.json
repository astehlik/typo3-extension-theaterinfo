{
    "name": "de-swebhosting-typo3-extension/theaterinfo",
    "description": "Theater info - Displays information about theater plays, actors and their roles and tasks",
    "license": "GPL-3.0-or-later",
    "type": "typo3-cms-extension",
    "keywords": [
        "TYPO3",
        "theater",
        "plays",
        "actors",
        "roles"
    ],
    "authors": [
        {
            "name": "Alexander Stehlik",
            "email": "alexander.stehlik.deleteme@gmail.com",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/astehlik/typo3-extension-theaterinfo",
    "support": {
        "issues": "https://github.com/astehlik/typo3-extension-theaterinfo/issues"
    },
    "require": {
        "php": "^8.2",
        "typo3/cms-core": "^14.0.0"
    },
    "require-dev": {
        "de-swebhosting/typo3-extension-buildtools": "dev-TYPO3_14",
        "michielroos/typo3scan": "dev-master",
        "phpunit/phpunit": "^11.5.50",
        "typo3/testing-framework": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "Sto\\Theaterinfo\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sto\\Theaterinfo\\Tests\\": "Tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        },
        "bin-dir": "bin",
        "vendor-dir": ".Build/vendor"
    },
    "extra": {
        "typo3/class-alias-loader": {
            "always-add-alias-loader": true
        },
        "typo3/cms": {
            "extension-key": "theaterinfo",
            "web-dir": ".Build/Web"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "De\\SWebhosting\\Buildtools\\ExtensionTestEnvironment::prepare"
        ]
    }
}
